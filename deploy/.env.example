# Production Environment Variables
# Copy this to .env and fill in your values

# Database
POSTGRES_USER=rarimo
POSTGRES_PASSWORD=rarimo

# Relayer private key (without 0x prefix)
# This wallet needs RMO tokens on Rarimo L2 Mainnet (Chain ID: 7368)
RELAYER_PRIVATE_KEY=YOUR_PRIVATE_KEY_WITHOUT_0X

# ============================================
# Agora Citizen Network (deliberation platform)
# See docker-compose.agora.yaml
# ============================================

# Required
AGORA_POSTGRES_USER=postgres
AGORA_POSTGRES_PASSWORD=GENERATE_A_SECURE_PASSWORD

# Peppers — comma-separated random hex strings for hashing
# Generate: node -e "console.log(Array.from({length:3},()=>require('crypto').randomBytes(32).toString('hex')).join(','))"
AGORA_PEPPERS=GENERATE_PEPPERS

# CORS — which origins can call the API
AGORA_CORS_ORIGINS=https://agora.jomhoor.org

# Verificator — Rarimo's hosted ZK passport verification service
AGORA_VERIFICATOR_SVC_URL=https://verificator.rarimo.com

# DID for the server (used in UCAN auth)
AGORA_SERVER_DID=did:web:agora.jomhoor.org

# AI / ML features (disable for MVP, enable when AWS Bedrock is configured)
AWS_AI_LABEL_SUMMARY_ENABLE=false
# AWS_AI_LABEL_SUMMARY_REGION=us-east-1
# AWS_AI_LABEL_SUMMARY_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

