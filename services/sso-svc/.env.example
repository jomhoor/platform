# Local dev overrides — never commit real secrets
# Copy to .env and fill in values before running locally.

SSO_DB_URL=postgres://sso:sso@localhost:5433/sso?sslmode=disable

# Generate with: openssl rand -hex 32
SSO_JWT_SECRET=

# Generate with: openssl rand -hex 32
SSO_PAIRWISE_SECRET=

# iOS App Attest
SSO_IOS_TEAM_ID=H2N3RZ4J46
SSO_IOS_BUNDLE_ID=org.jomhoor.app
# Use "development" for local/TestFlight; "production" for App Store builds
SSO_IOS_ATTEST_ENV=development

# Android Play Integrity
SSO_ANDROID_PACKAGE_NAME=org.jomhoor.app
# SHA-256 digests (base64) of upload cert + Play-managed cert, comma-separated
SSO_ANDROID_SIGNING_CERT_DIGESTS=
# Set to false locally (debug builds only reach MEETS_BASIC_INTEGRITY)
SSO_ANDROID_REQUIRE_STRONG_INTEGRITY=false
